# =================================================================
# WC2026 Office Leagues — environment variables
# Copy to `.env.local` for local dev and set each value.
# =================================================================

# ---- Site ----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"  # set to production domain in prod

# ---- Supabase ----
# Get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""  # server-only, never expose to client

# ---- Stripe ----
# Get from https://dashboard.stripe.com/apikeys (start in test mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""  # `stripe listen` produces this for local dev

# Stripe Product/Price IDs (create one Product per tier in Stripe Dashboard)
STRIPE_PRICE_STARTER=""    # £199
STRIPE_PRICE_PRO=""        # £499
STRIPE_PRICE_TEAM=""       # £999

# ---- Resend ----
# Get from https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="WC2026 Leagues <hello@yourdomain.com>"

# ---- API-Football (live results) ----
# https://www.api-football.com — free tier OK for dev
API_FOOTBALL_KEY=""

# ---- Job auth ----
# Used by Vercel Cron to authenticate against /api/ingest/results
CRON_SECRET=""  # generate via `openssl rand -hex 32`

# Used to sign invitation links so emails can't be spoofed
JOIN_LINK_SECRET=""  # generate via `openssl rand -hex 32`

# ---- Observability (PR 10) ----
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"  # or us.posthog.com
